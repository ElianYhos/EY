<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Elian y Yhos</title>

<style>
    body {
        margin: 0;
        background: #0d0d0d;
        color: white;
        font-family: 'Segoe UI', sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        flex-direction: column;
        overflow: hidden;
    }

    h1 {
        font-size: 3rem;
        letter-spacing: 3px;
        margin-bottom: 20px;
    }

    #texto {
        font-size: 2.5rem;
        min-height: 50px;
        border-right: 2px solid white;
        white-space: nowrap;
        overflow: hidden;
    }

    #subtexto {
        margin-top: 20px;
        font-size: 1.5rem;
        opacity: 0;
        transition: opacity 2s ease;
        color: #ff6b81;
    }

    canvas {
        position: absolute;
        bottom: 0;
    }
</style>
</head>

<body>

<div id="texto"></div>
<div id="subtexto">mi hilo rojo ❤️</div>

<canvas id="canvas"></canvas>

<<script>
document.addEventListener("DOMContentLoaded", () => {

const texto = "Elian y Yhos";
const contenedor = document.getElementById("texto");
const subtexto = document.getElementById("subtexto");

let i = 0;

function escribir() {
    if (i < texto.length) {
        contenedor.textContent += texto[i];
        i++;
        setTimeout(escribir, 150);
    } else {
        setTimeout(() => {
            subtexto.style.opacity = 1;
        }, 800);
    }
}

escribir();

});
</script>


</body>
</html>
